{
    "name": "web",
    "version": "1.0.0",
    "description": "ESP32 Web",
    "scripts": {
        "gen:types": "tsx scripts/generate-types.ts",
        "gen:pinia": "tsx scripts/generate-pinia.ts",
        "gen:client": "tsx scripts/generate-client.ts",
        "gen": "npm run gen:types && npm run gen:pinia && npm run gen:client",
        "gen:watch": "tsx scripts/watch-client.ts",
        "dev:frontend": "vite",
        "dev:backend": "tsx ./backend/server.ts",
        "dev": "MODE=sin    concurrently -n FRONT,BACK -c green,blue \"npm:dev:frontend\" \"npm:dev:backend\"",
        "dev2": "MODE=random concurrently -n FRONT,BACK -c green,blue \"npm:dev:frontend\" \"npm:dev:backend\"",
        "dev3": "MODE=static concurrently -n FRONT,BACK -c green,blue \"npm:dev:frontend\" \"npm:dev:backend\"",
        "prebuild": "npm run gen",
        "build": "vite build"
    },
    "keywords": [],
    "author": "Aleksey710",
    "license": "MIT",
    "type": "commonjs",
    "dependencies": {
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "chart.js": "^4.5.1",
        "fft": "^0.2.1",
        "fs-extra": "^11.3.4",
        "js-yaml": "^4.1.1",
        "pinia": "^3.0.4",
        "three": "^0.183.2",
        "vue": "^3.5.32",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.6.0",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "concurrently": "^9.2.1",
        "rollup-plugin-visualizer": "^7.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.3",
        "vue-tsc": "^3.2.7",
        "ws": "^8.20.0"
    }
}
